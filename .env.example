# Server Configuration
PORT=3000
NODE_ENV=development

# JWT Secrets (CHANGE THESE IN PRODUCTION!)
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production-2026
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-this-in-production-2026

# CORS Configuration (comma-separated for multiple origins)
CORS_ORIGIN=http://localhost:3000,http://127.0.0.1:3000

# Database (optional, defaults to data/tao-zi-jiao-map.db)
# DATABASE_PATH=./data/tao-zi-jiao-map.db

    # File Upload Limits (in bytes)
    MAX_FILE_SIZE=52428800